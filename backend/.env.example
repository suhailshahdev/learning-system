# Learning System Backend — environment template.
# Copy this file to .env and fill in values for local use.

# One of: local, test, production
ENVIRONMENT=local

# SQLAlchemy connection string.
# Postgres via the Docker Compose service is the primary local DB:
#   postgresql+psycopg://learning:learning@localhost:5432/learning
# psycopg (psycopg3) in sync mode. The async variant would be
# postgresql+psycopg_async://. We use sync SQLAlchemy throughout.
# SQLite remains usable for quick local runs and is what the test
# suite uses internally:
#   sqlite:///./learning.db
DATABASE_URL=postgresql+psycopg://learning:learning@localhost:5432/learning

# Origins allowed to make cross-origin requests to the API.
# JSON array syntax. Vite's dev server default is 5173
CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# Persistent Chrome profile directory for the Playwright transport.
# Default is ~/.config/learning-system/chrome-profile.
# Override only if you want the profile elsewhere.
# CHROME_PROFILE_PATH=/path/to/your/chrome-profile

# DeepSeek chat completions API. Required.
# Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# DeepSeek model identifier. Optional.
# Default: deepseek-v4-flash (efficiency tier, current).
# Alternative: deepseek-v4-pro (heavier, better reasoning).
DEEPSEEK_MODEL=deepseek-v4-flash
