# Learning System Backend — environment template.
# Copy this file to .env and fill in values for local use.

# One of: local, test, production
ENVIRONMENT=local

# SQLAlchemy connection string.
# For local development, SQLite in the backend directory is fine.
# The aiosqlite driver would be needed for async; we use sync SQLAlchemy for simplicity.
DATABASE_URL=sqlite:///./learning.db

# Origins allowed to make cross-origin requests to the API.
# JSON array syntax. Vite's dev server default is 5173
CORS_ALLOW_ORIGINS=["http://localhost:5173"]